# Database
DATABASE_URL=./portfolio.db

# Auth (BetterAuth)
BETTER_AUTH_SECRET=your-secret-key-change-in-production

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth - Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Email (Resend) — get a key at https://resend.com
# For local dev you can use the sandbox sender below; in production use a verified domain.
RESEND_API_KEY=
EMAIL_FROM="Portfolio Optimization <onboarding@resend.dev>"
